<UserControl x:Class="KConnect.Views.RegisterView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:KConnect.ViewModels"
             Background="#111111">

    <UserControl.DataContext>
        <vm:RegisterViewModel/>
    </UserControl.DataContext>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid VerticalAlignment="Center">
            <StackPanel Margin="48,32">

                <!-- Header -->
                <TextBlock Text="KConnect"
                           FontSize="38" FontWeight="Bold"
                           Foreground="#FF0000"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="Create your account"
                           FontSize="13" Foreground="#CCAC58"
                           HorizontalAlignment="Center"
                           Margin="0,6,0,36"/>

                <!-- Username -->
                <TextBlock Text="USERNAME"
                           Foreground="#666666" FontSize="11"
                           FontWeight="SemiBold" Margin="2,0,0,6"/>
                <TextBox Style="{StaticResource DarkInput}"
                         Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,0,0,4"/>
                <TextBlock Text="Letters, numbers and underscores. 3-32 characters."
                           Foreground="#555555" FontSize="11"
                           Margin="2,0,0,14"/>

                <!-- Email -->
                <TextBlock Text="EMAIL"
                           Foreground="#666666" FontSize="11"
                           FontWeight="SemiBold" Margin="2,0,0,6"/>
                <TextBox Style="{StaticResource DarkInput}"
                         Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,0,0,16"/>

                <!-- Phone (optional) -->
                <TextBlock Text="PHONE NUMBER (OPTIONAL)"
                           Foreground="#666666" FontSize="11"
                           FontWeight="SemiBold" Margin="2,0,0,6"/>
                <TextBox Style="{StaticResource DarkInput}"
                         Text="{Binding Phone, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,0,0,16"/>

                <!-- Password — named PwdBox to avoid collision with PasswordBox class -->
                <TextBlock Text="PASSWORD"
                           Foreground="#666666" FontSize="11"
                           FontWeight="SemiBold" Margin="2,0,0,6"/>
                <PasswordBox x:Name="PwdBox"
                             Style="{StaticResource DarkPasswordBox}"
                             Margin="0,0,0,16"/>

                <!-- Confirm Password — named ConfirmPwdBox -->
                <TextBlock Text="CONFIRM PASSWORD"
                           Foreground="#666666" FontSize="11"
                           FontWeight="SemiBold" Margin="2,0,0,6"/>
                <PasswordBox x:Name="ConfirmPwdBox"
                             Style="{StaticResource DarkPasswordBox}"
                             Margin="0,0,0,24"/>

                <!-- Error box -->
                <Border Background="#2A0000" CornerRadius="6" Padding="12,8"
                        Margin="0,0,0,12"
                        Visibility="{Binding HasError, Converter={StaticResource BoolToVisibility}}">
                    <TextBlock Text="{Binding ErrorMessage}"
                               Foreground="#FF6666" FontSize="12"
                               TextWrapping="Wrap"/>
                </Border>

                <!-- Success box -->
                <Border Background="#002A00" CornerRadius="6" Padding="12,8"
                        Margin="0,0,0,12"
                        Visibility="{Binding HasSuccess, Converter={StaticResource BoolToVisibility}}">
                    <TextBlock Text="{Binding SuccessMessage}"
                               Foreground="#66FF66" FontSize="12"
                               TextWrapping="Wrap"/>
                </Border>

                <!-- Create Account button -->
                <Button Style="{StaticResource PrimaryButton}"
                        Command="{Binding RegisterCommand}"
                        Height="44" Margin="0,0,0,20">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock Text="Create Account" FontSize="14"/>
                        <TextBlock Text="  ..." FontSize="14"
                                   Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibility}}"/>
                    </StackPanel>
                </Button>

                <!-- Login link — Button styled as link for reliable click handling -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <TextBlock Text="Already have an account? "
                               Foreground="#888888" FontSize="13"
                               VerticalAlignment="Center"/>
                    <Button Content="Sign in"
                            Style="{StaticResource LinkButton}"
                            Foreground="#CCAC58"
                            FontSize="13"
                            FontWeight="SemiBold"
                            Command="{Binding GoToLoginCommand}"/>
                </StackPanel>

            </StackPanel>
        </Grid>
    </ScrollViewer>
</UserControl>

<UserControl x:Class="KConnect.Views.ChatView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#111111"
             MinWidth="760" MinHeight="480">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>

        <Style x:Key="ConvItem" TargetType="ListBoxItem">
            <Setter Property="Background"  Value="Transparent"/>
            <Setter Property="Padding"     Value="12,10"/>
            <Setter Property="Cursor"      Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Bg" Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#1E1E1E"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#2A0000"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Scrollbar style — thin, dark -->
        <Style x:Key="ThinScrollBar" TargetType="ScrollBar">
            <Setter Property="Width" Value="6"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Track x:Name="PART_Track" IsDirectionReversed="True">
                            <Track.Thumb>
                                <Thumb>
                                    <Thumb.Template>
                                        <ControlTemplate TargetType="Thumb">
                                            <Border Background="#444444" CornerRadius="3"/>
                                        </ControlTemplate>
                                    </Thumb.Template>
                                </Thumb>
                            </Track.Thumb>
                        </Track>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ThinScrollViewer" TargetType="ScrollViewer">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollViewer">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <ScrollContentPresenter Grid.Column="0"/>
                            <ScrollBar Grid.Column="1"
                                       Style="{StaticResource ThinScrollBar}"
                                       Orientation="Vertical"
                                       Value="{TemplateBinding VerticalOffset}"
                                       Maximum="{TemplateBinding ScrollableHeight}"
                                       ViewportSize="{TemplateBinding ViewportHeight}"
                                       Visibility="{TemplateBinding ComputedVerticalScrollBarVisibility}"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280" MinWidth="200" MaxWidth="360"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ═══════════════════════════ SIDEBAR ═══════════════════════════ -->
        <Border Grid.Column="0" Background="#161616"
                BorderBrush="#2A2A2A" BorderThickness="0,0,1,0">
            <DockPanel>

                <!-- Top bar: logo + username + logout -->
                <Border DockPanel.Dock="Top" Background="#111111"
                        Padding="16,14" BorderBrush="#2A2A2A" BorderThickness="0,0,0,1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="KConnect" FontSize="18" FontWeight="Bold"
                                       Foreground="#FF0000"/>
                            <TextBlock Text="{Binding CurrentUsername}"
                                       Foreground="#CCAC58" FontSize="11"/>
                        </StackPanel>
                        <Button Grid.Column="1" Content="Sign out"
                                Style="{StaticResource LinkButton}"
                                Foreground="#666666" FontSize="11"
                                Command="{Binding LogoutCommand}"
                                VerticalAlignment="Center"/>
                    </Grid>
                </Border>

                <!-- Search / new conversation -->
                <Border DockPanel.Dock="Top" Padding="10,10"
                        BorderBrush="#2A2A2A" BorderThickness="0,0,0,1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0"
                                 x:Name="SearchBox"
                                 Style="{StaticResource DarkInput}"
                                 Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}"
                                 FontSize="13" Padding="10,8"/>
                        <Button Grid.Column="1" Content="+"
                                Style="{StaticResource PrimaryButton}"
                                FontSize="18" Padding="10,6"
                                Margin="6,0,0,0"
                                Command="{Binding SearchAndStartConversationCommand}"
                                ToolTip="Start a conversation"/>
                    </Grid>
                </Border>

                <!-- Search hint -->
                <TextBlock DockPanel.Dock="Top"
                           Text="Search by username or email"
                           Foreground="#444444" FontSize="11"
                           Margin="12,4,12,0"/>

                <!-- Error message -->
                <Border DockPanel.Dock="Top"
                        Background="#2A0000" CornerRadius="4" Padding="10,6" Margin="8,6,8,0"
                        Visibility="{Binding HasError, Converter={StaticResource BoolToVisibility}}">
                    <TextBlock Text="{Binding ErrorMessage}" Foreground="#FF6666"
                               FontSize="11" TextWrapping="Wrap"/>
                </Border>

                <!-- Conversation list -->
                <ListBox ItemsSource="{Binding Conversations}"
                         SelectedItem="{Binding SelectedConversation}"
                         Background="Transparent"
                         BorderThickness="0"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         ItemContainerStyle="{StaticResource ConvItem}">
                    <ListBox.Template>
                        <ControlTemplate TargetType="ListBox">
                            <ScrollViewer Style="{StaticResource ThinScrollViewer}" Focusable="False">
                                <ItemsPresenter/>
                            </ScrollViewer>
                        </ControlTemplate>
                    </ListBox.Template>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0"
                                           Text="{Binding DisplayName}"
                                           Foreground="White" FontSize="14"
                                           FontWeight="SemiBold"/>
                                <TextBlock Grid.Row="1"
                                           Text="{Binding LastMessagePreview}"
                                           Foreground="#777777" FontSize="12"
                                           TextTrimming="CharacterEllipsis"/>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

            </DockPanel>
        </Border>

        <!-- ═══════════════════════════ MAIN PANE ══════════════════════════ -->
        <Grid Grid.Column="1">

            <!-- Empty state -->
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                        Visibility="{Binding SelectedConversation, Converter={StaticResource NullToVisibility}}">
                <TextBlock Text="💬" FontSize="52" HorizontalAlignment="Center"/>
                <TextBlock Text="Select a conversation or search for someone above"
                           Foreground="#444444" FontSize="14"
                           HorizontalAlignment="Center" Margin="0,14,0,0"/>
            </StackPanel>

            <!-- Chat pane -->
            <Grid Visibility="{Binding SelectedConversation, Converter={StaticResource NotNullToVisibility}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Chat header -->
                <Border Grid.Row="0" Background="#161616"
                        Padding="20,14" BorderBrush="#2A2A2A" BorderThickness="0,0,0,1">
                    <TextBlock Text="{Binding SelectedConversation.DisplayName}"
                               Foreground="White" FontSize="16" FontWeight="SemiBold"/>
                </Border>

                <!-- Message list -->
                <ScrollViewer Grid.Row="1" x:Name="MessageScroller"
                              Style="{StaticResource ThinScrollViewer}"
                              VerticalScrollBarVisibility="Auto"
                              Padding="16,12">
                    <StackPanel>
                        <!-- Loading spinner -->
                        <TextBlock Text="Loading…"
                                   Foreground="#555555" FontSize="13"
                                   HorizontalAlignment="Center" Margin="0,20,0,0"
                                   Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibility}}"/>

                        <ItemsControl ItemsSource="{Binding Messages}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,3">
                                        <!-- Own messages — right-aligned red bubble -->
                                        <Border HorizontalAlignment="Right"
                                                MaxWidth="460"
                                                Background="#8B0000"
                                                CornerRadius="16,16,4,16"
                                                Padding="14,8"
                                                Margin="80,0,0,0">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsOwn}" Value="False">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <StackPanel>
                                                <TextBlock Text="{Binding Content}"
                                                           Foreground="White" FontSize="14"
                                                           TextWrapping="Wrap"/>
                                                <TextBlock Text="{Binding TimeLabel}"
                                                           Foreground="#FFAAAA" FontSize="10"
                                                           HorizontalAlignment="Right" Margin="0,4,0,0"/>
                                            </StackPanel>
                                        </Border>

                                        <!-- Their messages — left-aligned dark bubble -->
                                        <Border HorizontalAlignment="Left"
                                                MaxWidth="460"
                                                Background="#1E1E1E"
                                                CornerRadius="16,16,16,4"
                                                Padding="14,8"
                                                Margin="0,0,80,0">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsOwn}" Value="True">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <StackPanel>
                                                <TextBlock Text="{Binding SenderUsername}"
                                                           Foreground="#CCAC58" FontSize="11"
                                                           FontWeight="SemiBold" Margin="0,0,0,3"/>
                                                <TextBlock Text="{Binding Content}"
                                                           Foreground="White" FontSize="14"
                                                           TextWrapping="Wrap"/>
                                                <TextBlock Text="{Binding TimeLabel}"
                                                           Foreground="#666666" FontSize="10"
                                                           Margin="0,4,0,0"/>
                                            </StackPanel>
                                        </Border>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ScrollViewer>

                <!-- Typing indicator -->
                <Border Grid.Row="2" Padding="20,4"
                        Visibility="{Binding IsTypingVisible, Converter={StaticResource BoolToVisibility}}">
                    <TextBlock Text="{Binding TypingLabel}"
                               Foreground="#666666" FontSize="12"
                               FontStyle="Italic"/>
                </Border>

                <!-- Input bar -->
                <Border Grid.Row="3" Background="#161616"
                        Padding="16,10" BorderBrush="#2A2A2A" BorderThickness="0,1,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Named MsgInput to avoid conflict with System.Windows.MessageBox -->
                        <TextBox Grid.Column="0"
                                 x:Name="MsgInput"
                                 Style="{StaticResource DarkInput}"
                                 Text="{Binding MessageInput, UpdateSourceTrigger=PropertyChanged}"
                                 FontSize="14" Padding="12,10"
                                 AcceptsReturn="False"/>

                        <Button Grid.Column="1"
                                Content="Send"
                                Style="{StaticResource PrimaryButton}"
                                Margin="10,0,0,0"
                                Padding="20,10"
                                Command="{Binding SendMessageCommand}"/>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</UserControl>

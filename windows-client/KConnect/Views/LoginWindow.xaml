<Window x:Class="KConnect.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:KConnect.ViewModels"
        Title="KConnect" Height="520" Width="420"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#111111">

    <Window.DataContext>
        <vm:LoginViewModel/>
    </Window.DataContext>

    <Grid>
        <StackPanel VerticalAlignment="Center" Margin="48,0">

            <!-- Logo / Title -->
            <TextBlock Text="KConnect" FontSize="36" FontWeight="Bold"
                       Foreground="#FF0000" HorizontalAlignment="Center"/>
            <TextBlock Text="Sign in to your account" FontSize="14"
                       Foreground="#CCAC58" HorizontalAlignment="Center" Margin="0,6,0,32"/>

            <!-- Identifier -->
            <TextBlock Text="Username or Email" Foreground="#AAAAAA" FontSize="12" Margin="0,0,0,6"/>
            <TextBox Style="{StaticResource DarkInput}"
                     Text="{Binding Identifier, UpdateSourceTrigger=PropertyChanged}"
                     Margin="0,0,0,14"/>

            <!-- Password -->
            <TextBlock Text="Password" Foreground="#AAAAAA" FontSize="12" Margin="0,0,0,6"/>
            <PasswordBox x:Name="PasswordBox"
                         Style="{StaticResource DarkPasswordBox}"
                         Margin="0,0,0,6"/>

            <!-- MFA (hidden until needed) -->
            <StackPanel Visibility="{Binding MfaRequired, Converter={StaticResource BoolToVisibility}}"
                        Margin="0,8,0,0">
                <TextBlock Text="Authenticator Code" Foreground="#AAAAAA" FontSize="12" Margin="0,0,0,6"/>
                <TextBox Style="{StaticResource DarkInput}"
                         Text="{Binding MfaCode, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,0,0,14"/>
            </StackPanel>

            <!-- Error / Success -->
            <TextBlock Text="{Binding ErrorMessage}" Foreground="#FF4444"
                       FontSize="12" TextWrapping="Wrap" Margin="0,4,0,8"
                       Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibility}}"/>

            <!-- Login button -->
            <Button Content="{Binding IsBusy, Converter={StaticResource BusyToText}, ConverterParameter='Sign In|Signing in...'}"
                    Style="{StaticResource PrimaryButton}"
                    Command="{Binding LoginCommand}"
                    IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBool}}"
                    Margin="0,8,0,16" Height="42"/>

            <!-- Register link -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <TextBlock Text="No account? " Foreground="#888888" FontSize="13"/>
                <TextBlock Text="Create one" Foreground="#CCAC58" FontSize="13" Cursor="Hand">
                    <TextBlock.InputBindings>
                        <MouseBinding MouseAction="LeftClick" Command="{Binding GoToRegisterCommand}"/>
                    </TextBlock.InputBindings>
                </TextBlock>
            </StackPanel>

        </StackPanel>
    </Grid>
</Window>